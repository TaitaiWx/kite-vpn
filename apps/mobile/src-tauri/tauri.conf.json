{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Kite",
  "version": "0.1.0",
  "identifier": "com.kite.mobile",
  "build": {
    "beforeDevCommand": "cd ../../packages/ui && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd ../../packages/ui && pnpm build",
    "frontendDist": "../../packages/ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kite",
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https: http://127.0.0.1:* http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "libs/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "minimumSystemVersion": "15.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
  }
}
