# Kite 自托管 —— docker-compose 部署用
# 拷一份到 .env (`cp .env.example .env`) 再改值，永远别 commit .env

# ─── 必填 ────────────────────────────────────────────────────────────────────
KITE_DOMAIN=kite.example.com
KITE_PUBLIC_URL=https://kite.example.com
KITE_FRONTEND_REDIRECT_URL=https://kite.example.com

# ─── 数据库（compose volume 内）─────────────────────────────────────────────
KITE_DATABASE_URL=sqlite:/var/lib/kite/kite.db
KITE_COOKIE_SECURE=true

# ─── Mailer (Resend / Mailgun / 任何 SMTP 服务) ─────────────────────────────
KITE_MAILER=smtp
KITE_SMTP_HOST=smtp.resend.com
KITE_SMTP_PORT=587
KITE_SMTP_USER=resend
KITE_SMTP_PASS=REPLACE_ME_with_real_password
KITE_SMTP_FROM_EMAIL=login@kite.example.com
KITE_SMTP_FROM_NAME=Kite

# ─── Nebula Lighthouse 参数 ─────────────────────────────────────────────────
KITE_NEBULA_PORT=4242
KITE_NEBULA_LISTEN_HOST=::

# ─── 自动更新源（可选）─────────────────────────────────────────────────────
# 默认透传 GitHub Releases。自托管 CDN 时改这里：
# KITE_UPDATE_SOURCE_URL=https://cdn.your-org.com/kite/latest.json
# KITE_UPDATE_CACHE_SECS=300

# ─── 日志 ───────────────────────────────────────────────────────────────────
RUST_LOG=info,kite_backend=info,tower_http=warn
