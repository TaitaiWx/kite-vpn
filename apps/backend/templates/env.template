# Kite 环境变量（systemd EnvironmentFile / docker-compose env_file 都用这个）
#
# ⚠️ 这个文件含 SMTP 密码，权限必须 0600。

# ─── 后端 HTTP 服务 ──────────────────────────────────────────────────────────
KITE_DATABASE_URL=sqlite:/var/lib/kite/kite.db
KITE_BIND=127.0.0.1:8787
KITE_PUBLIC_URL=https://kite.example.com
KITE_FRONTEND_REDIRECT_URL=https://kite.example.com
KITE_COOKIE_SECURE=true

# ─── Mailer (magic link) ─────────────────────────────────────────────────────
# stdout: dev 模式，token 打到日志（用 `journalctl -u kite-backend` 看）
# smtp:   prod 模式，走真实邮件
KITE_MAILER=smtp
KITE_SMTP_HOST=smtp.resend.com
KITE_SMTP_PORT=587
KITE_SMTP_USER=resend
KITE_SMTP_PASS=__REPLACE_ME__
KITE_SMTP_FROM_EMAIL=login@kite.example.com
KITE_SMTP_FROM_NAME=Kite

# ─── Nebula Lighthouse 子进程（同一 service 内托管）─────────────────────────
# 两个变量都设 → kite-backend 启动时自动 spawn nebula；都不设 → 退化为纯后端
KITE_NEBULA_BIN=/usr/local/bin/nebula
KITE_NEBULA_CONFIG=/etc/kite/nebula.yaml

# ─── 自动更新 endpoint ───────────────────────────────────────────────────────
# /api/updates/latest.json 透传的上游地址。默认就是 GitHub Releases，所以可省略。
# 自托管时把这里改成你自己的 latest.json 地址（比如内网 CDN）即可。
# KITE_UPDATE_SOURCE_URL=https://github.com/TaitaiWx/kite-vpn/releases/latest/download/latest.json
# KITE_UPDATE_CACHE_SECS=300

# ─── 日志 ────────────────────────────────────────────────────────────────────
RUST_LOG=info,kite_backend=info,tower_http=warn
