# Kite Backend 环境变量（systemd EnvironmentFile）—— deploy.sh 渲染
#
# ⚠️ 这个文件含 SMTP 密码，权限必须 0600，归属 kite-backend 用户。

KITE_DATABASE_URL=sqlite:/var/lib/kite-backend/kite.db
KITE_BIND=127.0.0.1:__BACKEND_PORT__
KITE_PUBLIC_URL=https://__DOMAIN__
KITE_FRONTEND_REDIRECT_URL=__FRONTEND_REDIRECT_URL__
KITE_COOKIE_SECURE=true

# Mailer: stdout (dev) / smtp (prod)
KITE_MAILER=__MAILER_KIND__

# 仅 KITE_MAILER=smtp 时下面这些字段才用得到
KITE_SMTP_HOST=__SMTP_HOST__
KITE_SMTP_PORT=__SMTP_PORT__
KITE_SMTP_USER=__SMTP_USER__
KITE_SMTP_PASS=__SMTP_PASS__
KITE_SMTP_FROM_EMAIL=__SMTP_FROM_EMAIL__
KITE_SMTP_FROM_NAME=__SMTP_FROM_NAME__

# tracing 日志级别
RUST_LOG=info,kite_backend=info,tower_http=warn
